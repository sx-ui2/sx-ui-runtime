+func registerManagedMetrics(registry *prometheus.Registry) {
+	managedMetricsOnce.Do(func() {
+		managedUserUpBytes = prometheus.NewCounterVec(
+			prometheus.CounterOpts{
+				Name: "sx_ui_naive_user_up_bytes_total",
+				Help: "Total authenticated upstream bytes per naive proxy user.",
+			},
+			[]string{"proxy", "user"},
+		)
+		managedUserDownBytes = prometheus.NewCounterVec(
+			prometheus.CounterOpts{
+				Name: "sx_ui_naive_user_down_bytes_total",
+				Help: "Total authenticated downstream bytes per naive proxy user.",
+			},
+			[]string{"proxy", "user"},
+		)
+		managedAuthFailures = prometheus.NewCounterVec(
+			prometheus.CounterOpts{
+				Name: "sx_ui_naive_auth_failures_total",
+				Help: "Total failed proxy authentication attempts per naive proxy site.",
+			},
+			[]string{"proxy"},
+		)
+		managedActiveConnections = prometheus.NewGaugeVec(
+			prometheus.GaugeOpts{
+				Name: "sx_ui_naive_active_connections",
+				Help: "Current in-flight authenticated proxy connections per naive proxy user.",
+			},
+			[]string{"proxy", "user"},
+		)
+	})
+	if registry == nil {
+		return
+	}
+	for _, collector := range []prometheus.Collector{
+		managedUserUpBytes,
+		managedUserDownBytes,
+		managedAuthFailures,
+		managedActiveConnections,
+	} {
+		if err := registry.Register(collector); err != nil {
+			var already prometheus.AlreadyRegisteredError
+			if !errors.As(err, &already) {
+				panic(err)
+			}
+		}
+	}
+}
+
+func (h Handler) observeAuthFailure() {
+	proxyName := strings.TrimSpace(h.StatsName)
+	if proxyName == "" || managedAuthFailures == nil {
+		return
+	}
+	managedAuthFailures.WithLabelValues(proxyName).Inc()
+}
+
+func (h Handler) newStatsTracker(r *http.Request) *statsTracker {
+	proxyName := strings.TrimSpace(h.StatsName)
+	userID := strings.TrimSpace(readAuthUserID(r))
+	if proxyName == "" || userID == "" || managedActiveConnections == nil {
+		return nil
+	}
+	tracker := &statsTracker{
+		proxy: proxyName,
+		user:  userID,
+	}
+	managedActiveConnections.WithLabelValues(tracker.proxy, tracker.user).Inc()
+	return tracker
+}
+
+func readAuthUserID(r *http.Request) string {
+	if r == nil {
+		return ""
+	}
+	repl, ok := r.Context().Value(caddy.ReplacerCtxKey).(*caddy.Replacer)
+	if !ok || repl == nil {
+		return ""
+	}
+	value, ok := repl.GetString("http.auth.user.id")
+	if !ok {
+		return ""
+	}
+	userID := strings.TrimSpace(value)
+	if strings.HasPrefix(userID, "invalid") {
+		return ""
+	}
+	return userID
+}
+
+type statsTracker struct {
+	proxy string
+	user  string
+}
+
+func (t *statsTracker) AddUp(bytes int64) {
+	if t == nil || bytes <= 0 || managedUserUpBytes == nil {
+		return
+	}
+	managedUserUpBytes.WithLabelValues(t.proxy, t.user).Add(float64(bytes))
+}
+
+func (t *statsTracker) AddDown(bytes int64) {
+	if t == nil || bytes <= 0 || managedUserDownBytes == nil {
+		return
+	}
+	managedUserDownBytes.WithLabelValues(t.proxy, t.user).Add(float64(bytes))
+}
+
+func (t *statsTracker) Done() {
+	if t == nil || managedActiveConnections == nil {
+		return
+	}
+	managedActiveConnections.WithLabelValues(t.proxy, t.user).Dec()
+}
+
+type countingReadCloser struct {
+	io.ReadCloser
+	count int64
+}
+
+func (c *countingReadCloser) Read(p []byte) (int, error) {
+	n, err := c.ReadCloser.Read(p)
+	c.count += int64(n)
+	return n, err
+}
+
+func (c *countingReadCloser) Count() int64 {
+	if c == nil {
+		return 0
+	}
+	return c.count
 }
 
